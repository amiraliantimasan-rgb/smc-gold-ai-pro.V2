//@version=5
indicator("SMC Gold AI PRO v1.2 - Strong Signals Engine", overlay=true, max_labels_count=500)

//========================
// Inputs
//========================
leftBars  = input.int(5, "Left Bars", minval=1)
rightBars = input.int(5, "Right Bars", minval=1)
showLabels = input.bool(true, "Show Structure")
showSignals = input.bool(true, "Show BUY/SELL Signals")

atrLen = input.int(14, "ATR Length")
atrMult = input.float(0.6, "Institutional ATR Mult")
strongMult = input.float(1.2, "Strong Signal ATR Mult")

//========================
// Swing Detection
//========================
ph = ta.pivothigh(high, leftBars, rightBars)
pl = ta.pivotlow(low, leftBars, rightBars)

var float lastHigh = na
var float lastLow  = na
var int trend = 0

atr = ta.atr(atrLen)
body = math.abs(close - open)

//========================
// Update Swings
//========================
if not na(ph)
    lastHigh := ph
if not na(pl)
    lastLow := pl

//========================
// Strength Filters
//========================
bullStrength = body > atr * atrMult and close > open
bearStrength = body > atr * atrMult and close < open

strongBull = body > atr * strongMult and close > open
strongBear = body > atr * strongMult and close < open

//========================
// Break Logic
//========================
bullBreak = not na(lastHigh) and close > lastHigh and bullStrength
bearBreak = not na(lastLow) and close < lastLow and bearStrength

//========================
// Structure Events
//========================
if bullBreak
    isChoch = trend == -1
    label.new(bar_index, high, isChoch ? "CHoCH ↑" : "BOS ↑", style=label.style_label_up, color=color.green, textcolor=color.white)
    trend := 1

if bearBreak
    isChoch = trend == 1
    label.new(bar_index, low, isChoch ? "CHoCH ↓" : "BOS ↓", style=label.style_label_down, color=color.red, textcolor=color.white)
    trend := -1

//========================
// Strong BUY/SELL Signals
//========================
strongBuy = showSignals and trend == 1 and bullBreak and strongBull
strongSell = showSignals and trend == -1 and bearBreak and strongBear

if strongBuy
    label.new(bar_index, low, "STRONG BUY", style=label.style_label_up, color=color.lime, textcolor=color.black)

if strongSell
    label.new(bar_index, high, "STRONG SELL", style=label.style_label_down, color=color.red, textcolor=color.white)

//========================
// Swing Markers
//========================
if showLabels and not na(ph)
    label.new(bar_index - rightBars, ph, "SH", color=color.gray, textcolor=color.white)

if showLabels and not na(pl)
    label.new(bar_index - rightBars, pl, "SL", color=color.gray, textcolor=color.white)